{
  "name": "@adddog/build-configs",
  "version": "0.0.13",
  "description": "Reusable build configurations for tsup and unbuild",
  "type": "module",
  "author": "Sam Elie <sam@add.dog>",
  "license": "MIT",
  "homepage": "https://github.com/samelie/build-configs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/samelie/build-configs.git"
  },
  "bugs": {
    "url": "https://github.com/samelie/build-configs/issues"
  },
  "keywords": [
    "tsup",
    "unbuild",
    "build-config",
    "typescript",
    "bundler"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "rad-build": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./tsup": {
      "import": "./src/tsup.config.ts"
    },
    "./unbuild": {
      "import": "./src/unbuild.config.ts"
    },
    "./presets": {
      "import": "./src/presets/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "release": "bumpp --yes --no-push --no-tag --release patch",
    "types": "tsc -p tsconfig.typecheck.json",
    "prepack": "pnpm run prepublishOnly",
    "test": "vitest --watch=false",
    "dev": "tsx src/index.ts",
    "knip": "knip",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "defu": "^6.1.4",
    "execa": "^9.6.1",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.1",
    "tsup": "^8.5.1",
    "unbuild": "^3.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@adddog/monorepo-consistency": "workspace:*",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "./tsup": {
        "types": "./dist/tsup.config.d.ts",
        "import": "./dist/tsup.config.mjs"
      },
      "./unbuild": {
        "types": "./dist/unbuild.config.d.ts",
        "import": "./dist/unbuild.config.mjs"
      },
      "./presets": {
        "types": "./dist/presets/index.d.ts",
        "import": "./dist/presets/index.mjs"
      }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.ts"
  },
  "engines": {
    "node": ">= 22",
    "pnpm": ">= 10",
    "npm": ">= 11"
  },
  "private": true
}
